#!/bin/sh

# tools/setup: Set up for the first time after cloning, or set it
#               back to the initial first unused state.

set -e
cd "$(dirname "$0")/.."
echo "==> Running tools/setup…"

tools/clean
tools/bootstrap

# Build, publish, and minify the site
echo "==> Building site…"
hugo --minify

# Done
echo "==> tools/setup done."
